{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "EmployeeNumber": {
      "type": "string",
      "pattern": "^[0-9]{6,8}$"
    },
    "SSNValue": {
      "type": "string"
    },
    "FirstName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 255
    },
    "LastName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 255
    },
    "DateOfBirth": {
      "type": "string",
      "pattern": "^\\d{2}\\.\\d{2}\\.\\d{4}$"
    },
    "HomeStreet1": {
      "type": "string"
    },
    "HomeCity": {
      "type": "string"
    },
    "HomeZip": {
      "type": "string"
    },
    "HomeCountry": {
      "type": "string"
    },
    "Organization.Code": {
      "type": "string"
    },
    "Department.Code": {
      "type": "string"
    },
    "Supervisor": {
      "type": "string"
    },
    "Email": {
      "type": "string"
    },
    "LoginId": {
      "type": "string"
    },
    "CostCenter": {
      "type": "string"
    },
    "PositionCode": {
      "type": "string"
    },
    "PositionDescription": {
      "type": "string"
    }
  },
  "required": [
    "EmployeeNumber",
    "FirstName",
    "LastName"
  ]
}