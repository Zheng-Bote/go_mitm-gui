{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ORG Data Schema",
  "description": "Schema for ORG master data records from Kafka",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "ClockInOut": { "type": "string" },
      "CostCenter": { "type": "string" },
      "Country": { "type": "string", "minLength": 2, "maxLength": 3 },
      "Department": { "type": "string" },
      "DepartmentManager": { "type": "string" },
      "DepartmentManagerText": { "type": "string" },
      "DepartmentText": { "type": "string" },
      "EmployeeGroup": { "type": "string" },
      "EmployeeID": { "type": "string" },
      "EmployeeSubGroup": { "type": "string" },
      "EndDate": { "type": "string", "format": "date" },
      "EntryDate": { "type": "string" },
      "ExitDate": { "type": "string" },
      "FunctionalLevelManager": { "type": "string" },
      "LegacyID": { "type": "string" },
      "LegalEntity": { "type": "string" },
      "Location": { "type": "string" },
      "ManagerID": { "type": "string" },
      "PersonnelArea": { "type": "string" },
      "StartDate": { "type": "string", "format": "date" },
      "Status": { "type": "string", "enum": ["A", "D", "I", "P"] },
      "WorkingStructure": { "type": "string" }
    },
    "required": ["EmployeeID", "StartDate", "EndDate", "Status"]
  }
}
